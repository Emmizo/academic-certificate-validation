<!DOCTYPE html>
<html lang="en" xmlns:th="http://www.thymeleaf.org"
      th:replace="layout :: layout(~{::title}, ~{::main})">
<head>
    <title>Verify Certificate Authenticity</title>
</head>
<body>
<main>
    <div class="max-w-3xl mx-auto">
        <h1 class="text-2xl font-bold text-slate-900">Verify Certificate Authenticity</h1>
        <p class="mt-1 text-sm text-slate-600">Enter a Certificate ID to validate its digital signature.</p>

        <form class="mt-6 flex gap-2" th:action="@{/verify}" method="post">
            <input type="hidden" th:name="${_csrf.parameterName}" th:value="${_csrf.token}"/>

            <input name="certificateId" type="text" placeholder="e.g., CERT-1A2B3C4D" required
                   th:value="${certificateId}"
                   class="flex-1 rounded-lg border border-slate-300 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-600"/>
            <button type="submit"
                    class="rounded-lg bg-blue-600 px-4 py-2 font-semibold text-white hover:bg-blue-700">
                Verify
            </button>
        </form>

        <div class="mt-6" th:if="${result != null}">
            <div th:if="${result.valid}"
                 class="rounded-xl border border-emerald-200 bg-emerald-50 p-5">
                <div class="flex items-start gap-3">
                    <div class="h-10 w-10 rounded-full bg-emerald-600 text-white flex items-center justify-center font-bold">✓</div>
                    <div class="flex-1">
                        <div class="text-lg font-semibold text-emerald-900">VALID Certificate</div>
                        <div class="text-sm text-emerald-900/80">Signature verified successfully.</div>
                    </div>
                    <div class="text-xs text-emerald-900/70" th:text="${#temporals.format(result.verifiedAt, 'yyyy-MM-dd HH:mm:ss')}"></div>
                </div>

                <div class="mt-4 grid grid-cols-1 sm:grid-cols-2 gap-4">
                    <div>
                        <div class="text-xs text-emerald-900/70">Student Name</div>
                        <div class="font-semibold" th:text="${result.certificate.studentName}"></div>
                    </div>
                    <div>
                        <div class="text-xs text-emerald-900/70">Student ID</div>
                        <div class="font-semibold" th:text="${result.certificate.studentId}"></div>
                    </div>
                    <div>
                        <div class="text-xs text-emerald-900/70">Degree</div>
                        <div class="font-semibold" th:text="${result.certificate.degree}"></div>
                    </div>
                    <div>
                        <div class="text-xs text-emerald-900/70">Institution</div>
                        <div class="font-semibold" th:text="${result.certificate.institution}"></div>
                    </div>
                    <div>
                        <div class="text-xs text-emerald-900/70">Issue Date</div>
                        <div class="font-semibold" th:text="${result.certificate.issueDate}"></div>
                    </div>
                    <div>
                        <div class="text-xs text-emerald-900/70">Certificate ID</div>
                        <div class="font-mono font-semibold" th:text="${result.certificate.certificateId}"></div>
                    </div>
                </div>

                <details class="mt-5 rounded-lg border border-emerald-200 bg-white p-4">
                    <summary class="cursor-pointer text-sm font-semibold text-slate-900">Cryptographic details</summary>
                    <div class="mt-3 space-y-3">
                        <div>
                            <div class="text-xs text-slate-500">Document Hash (SHA-256)</div>
                            <div class="mt-1 font-mono text-xs break-all" th:text="${result.certificate.documentHash}"></div>
                        </div>
                        <div>
                            <div class="text-xs text-slate-500">Digital Signature (Base64, truncated)</div>
                            <div class="mt-1 font-mono text-xs break-all"
                                 th:text="${#strings.abbreviate(result.certificate.digitalSignature, 120)}"></div>
                        </div>
                    </div>
                </details>
            </div>

            <div th:if="${!result.valid}"
                 class="rounded-xl border border-red-200 bg-red-50 p-5">
                <div class="flex items-start gap-3">
                    <div class="h-10 w-10 rounded-full bg-red-600 text-white flex items-center justify-center font-bold">!</div>
                    <div class="flex-1">
                        <div class="text-lg font-semibold text-red-900">INVALID Certificate</div>
                        <div class="text-sm text-red-900/80" th:text="${result.failureReason}"></div>
                    </div>
                    <div class="text-xs text-red-900/70" th:text="${#temporals.format(result.verifiedAt, 'yyyy-MM-dd HH:mm:ss')}"></div>
                </div>
            </div>
        </div>
    </div>
</main>
</body>
</html>


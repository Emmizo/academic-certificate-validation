<!DOCTYPE html>
<html lang="en" xmlns:th="http://www.thymeleaf.org"
      th:replace="layout :: layout(~{::title}, ~{::main})">
<head>
    <title>Admin Dashboard</title>
</head>
<body>
<main>
    <div class="flex items-start justify-between gap-4">
        <div>
            <h1 class="text-2xl font-bold text-slate-900">Dashboard</h1>
            <p class="mt-1 text-sm text-slate-600">
                Welcome, <span class="font-semibold" th:text="${username}"></span>.
            </p>
        </div>
        <div class="flex gap-2">
            <a th:href="@{/admin/issue}"
               class="rounded-lg bg-blue-600 px-4 py-2 text-sm font-semibold text-white hover:bg-blue-700">
                Issue New Certificate
            </a>
            <a th:href="@{/admin/keys}"
               class="rounded-lg border border-slate-300 bg-white px-4 py-2 text-sm font-semibold text-slate-800 hover:bg-slate-50">
                Manage Keys
            </a>
        </div>
    </div>

    <div class="mt-6 grid grid-cols-1 md:grid-cols-3 gap-4">
        <div class="rounded-xl border border-slate-200 bg-white p-6">
            <div class="text-xs text-slate-500">Total Certificates Issued</div>
            <div class="mt-2 text-3xl font-bold text-slate-900" th:text="${totalCerts}">0</div>
        </div>
        <div class="rounded-xl border border-slate-200 bg-white p-6">
            <div class="text-xs text-slate-500">Active Key Status</div>
            <div class="mt-2 text-lg font-semibold"
                 th:classappend="${activeKeyPresent} ? 'text-emerald-700' : 'text-red-700'"
                 th:text="${activeKeyPresent} ? 'ACTIVE' : 'NOT GENERATED'">
                ACTIVE
            </div>
            <div class="mt-1 text-xs text-slate-500" th:if="${activeKeyCreatedAt != null}"
                 th:text="'Generated: ' + ${#temporals.format(activeKeyCreatedAt, 'yyyy-MM-dd HH:mm:ss')}"></div>
        </div>
        <div class="rounded-xl border border-slate-200 bg-white p-6">
            <div class="text-xs text-slate-500">Last Certificate Date</div>
            <div class="mt-2 text-lg font-semibold text-slate-900"
                 th:text="${lastCertificateDate != null} ? ${lastCertificateDate} : '—'">
                —
            </div>
        </div>
    </div>

    <div class="mt-8 rounded-2xl border border-slate-200 bg-white p-6">
        <h2 class="text-lg font-semibold text-slate-900">Quick Actions</h2>
        <div class="mt-4 grid grid-cols-1 md:grid-cols-3 gap-3">
            <a th:href="@{/admin/issue}" class="rounded-xl border border-slate-200 p-4 hover:bg-slate-50">
                <div class="font-semibold">Issue New Certificate</div>
                <div class="mt-1 text-sm text-slate-600">Create and digitally sign a new certificate.</div>
            </a>
            <a th:href="@{/admin/keys}" class="rounded-xl border border-slate-200 p-4 hover:bg-slate-50">
                <div class="font-semibold">Manage Keys</div>
                <div class="mt-1 text-sm text-slate-600">Generate and rotate RSA key pairs.</div>
            </a>
            <a th:href="@{/admin/certificates}" class="rounded-xl border border-slate-200 p-4 hover:bg-slate-50">
                <div class="font-semibold">View All Certificates</div>
                <div class="mt-1 text-sm text-slate-600">Browse issued certificates and details.</div>
            </a>
        </div>
    </div>
</main>
</body>
</html>

